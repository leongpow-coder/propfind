<script is:inline>
(function () {
  // Scroll-reveal for .reveal elements
  var revealObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.reveal').forEach(function (el) {
    revealObserver.observe(el);
  });

  // Quote band reveal
  var quoteObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        quoteObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.quote-band').forEach(function (el) {
    quoteObserver.observe(el);
  });

  // Comparison table rows stagger
  var rowObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        var rows = entry.target.querySelectorAll('tbody tr');
        rows.forEach(function (row, i) {
          setTimeout(function () {
            row.classList.add('visible');
          }, i * 80);
        });
        rowObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.compare-table').forEach(function (el) {
    rowObserver.observe(el);
  });
})();
</script>
</Layout>
