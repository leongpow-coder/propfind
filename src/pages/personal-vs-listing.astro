---
import Layout from '../layouts/Layout.astro';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Personal Page vs Portal Listing for Singapore Property Agents',
  description: 'Why Singapore property agents with a personal page win more clients than those relying on portals like PropertyGuru or 99.co.',
  datePublished: '2025-01-01T00:00:00+08:00',
  dateModified: '2026-03-24T00:00:00+08:00',
  author: {
    '@type': 'Organization',
    name: 'Prop Find',
    url: 'https://www.propfind.me',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Prop Find',
    url: 'https://www.propfind.me',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.propfind.me/assets/images/apple-touch-icon.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://www.propfind.me/personal-vs-listing',
  },
  image: 'https://www.propfind.me/og/personal-vs-listing.png',
  inLanguage: 'en-SG',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Why should a Singapore property agent have a personal landing page?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A personal landing page lets clients see your credentials, testimonials, and track record in one place — without competing agents beside you. It builds trust before the first conversation and ranks your name directly on Google, unlike portal profiles.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the difference between a personal page and a portal listing?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A portal listing on PropertyGuru or 99.co shows your profile alongside dozens of other agents, with the portal\'s brand ranking on Google instead of yours. A personal landing page is owned by you, showcases only you, and gives clients a clean first impression through one shareable link.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does a Prop Find personal page cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A Prop Find personal landing page costs $20 per year, all-in. The page is built for you — no tech skills required.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can clients find me on Google with a personal landing page?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. When clients search your name, your personal page surfaces directly in Google results. On portals, it is the portal that ranks — not you personally.',
      },
    },
  ],
};
---

<Layout
  title="Personal Page vs Portal Listing for Singapore Property Agents — Prop Find"
  description="Why Singapore property agents with a personal page win more clients than those relying on portals like PropertyGuru or 99.co."
  ogSlug="personal-vs-listing"
  canonicalPath="/personal-vs-listing"
  ogType="article"
  extraSchema={[articleSchema, faqSchema]}
>
<Fragment slot="head">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,300;1,9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
</Fragment>

<style is:global>
  /* ── TOKENS ── */
  :root {
    --navy:       oklch(18% 0.04 260);
    --navy-mid:   oklch(25% 0.04 260);
    --accent:     oklch(44% 0.14 250);
    --accent-lt:  oklch(65% 0.12 250);
    --cream:      oklch(97% 0.008 80);
    --cream-2:    oklch(93% 0.01 80);
    --ink:        oklch(20% 0.02 260);
    --ink-2:      oklch(38% 0.02 260);
    --ink-3:      oklch(55% 0.015 260);
    --border:     oklch(88% 0.01 260);

    --ff-display: 'Fraunces', Georgia, serif;
    --ff-body:    'Plus Jakarta Sans', system-ui, sans-serif;

    --ease-out-expo:  cubic-bezier(0.16, 1, 0.3, 1);
    --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--ff-body);
    background: var(--cream);
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── NAV ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
    height: 60px;
    border-bottom: 1px solid oklch(30% 0.04 260);
  }
  .nav-brand {
    font-family: var(--ff-display);
    font-weight: 700;
    font-size: 1.125rem;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .nav-brand span { color: var(--accent-lt); }
  .nav-cta {
    font-family: var(--ff-body);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    padding: 0.5rem 1.25rem;
    border-radius: 2px;
    text-decoration: none;
    transition: opacity 120ms;
  }
  .nav-cta:hover { opacity: 0.85; }

  /* ── HERO ── */
  .hero {
    background: var(--navy);
    color: #fff;
    padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 3rem) clamp(3rem, 7vw, 5rem);
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 60%, oklch(44% 0.14 250 / 0.18), transparent);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 780px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .hero-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-lt);
    margin-bottom: 1.5rem;
  }
  .hero-kicker::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 2px;
    background: var(--accent-lt);
  }
  .hero-kicker::after {
    content: '';
    display: block;
    width: 1.5rem;
    height: 2px;
    background: var(--accent-lt);
  }
  .hero h1 {
    font-family: var(--ff-display);
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 auto 1.75rem;
    max-width: 780px;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--accent-lt);
  }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.175rem);
    color: oklch(80% 0.02 260);
    line-height: 1.75;
    max-width: 52ch;
    margin: 0 auto 2.5rem;
    font-weight: 400;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.875rem 2rem;
    border-radius: 2px;
    text-decoration: none;
    transition: transform 200ms var(--ease-out-quart), opacity 150ms;
  }
  .btn-hero:hover { transform: translateY(-2px); opacity: 0.9; }
  .btn-hero svg { width: 1rem; height: 1rem; fill: currentColor; flex-shrink: 0; }
  .hero-note {
    font-size: 0.8125rem;
    color: oklch(65% 0.02 260);
    font-style: italic;
  }

  /* ── STATS GRID ── */
  .stats-wrap {
    background: var(--navy);
    border-top: 1px solid oklch(28% 0.04 260);
    padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 5vw, 3rem);
  }
  .stats-grid {
    max-width: 640px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: oklch(28% 0.04 260);
    border: 1px solid oklch(28% 0.04 260);
    border-radius: 4px;
    overflow: hidden;
  }
  .stat-item {
    background: var(--navy-mid);
    padding: 1.5rem 1.75rem;
    text-align: center;
  }
  .stat-item strong {
    display: block;
    font-family: var(--ff-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums;
  }
  .stat-item span {
    font-size: 0.8125rem;
    color: oklch(70% 0.02 260);
    font-weight: 500;
    line-height: 1.4;
  }

  /* ── SECTION BASE ── */
  .wrap {
    padding: clamp(3.5rem, 8vw, 6rem) clamp(1.5rem, 5vw, 3rem);
  }
  .wrap--cream  { background: var(--cream); }
  .wrap--cream2 { background: var(--cream-2); }

  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .section-label::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 2px;
    background: var(--accent);
  }

  .section-heading {
    font-family: var(--ff-display);
    font-weight: 900;
    font-size: clamp(1.875rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
    color: var(--ink);
  }

  .section-lead {
    font-size: 1.0625rem;
    color: var(--ink-2);
    line-height: 1.75;
    max-width: 56ch;
    margin-bottom: 3rem;
  }

  /* ── COMPARISON TABLE ── */
  .table-wrap {
    overflow-x: auto;
    border-radius: 4px;
    border: 1px solid var(--border);
    box-shadow: 0 2px 24px oklch(20% 0.04 260 / 0.06);
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    background: #fff;
    min-width: 600px;
  }
  .cmp-table thead tr {
    background: var(--navy);
    color: #fff;
  }
  .cmp-table th {
    padding: 1.125rem 1.5rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: oklch(65% 0.02 260);
  }
  .cmp-table th:first-child { width: 32%; color: #fff; }
  .cmp-table th:last-child  { color: oklch(75% 0.12 145); }
  .cmp-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 150ms;
  }
  .cmp-table tbody tr:last-child { border-bottom: none; }
  .cmp-table tbody tr:hover { background: var(--cream); }
  .cmp-table td {
    padding: 1rem 1.5rem;
    vertical-align: middle;
    line-height: 1.55;
  }
  .cmp-table td:first-child {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }
  .col-no, .col-yes {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.9rem;
  }
  .col-no  { color: oklch(48% 0.08 20); }
  .col-yes { color: oklch(35% 0.12 145); font-weight: 600; }
  .icon-x, .icon-ck {
    flex-shrink: 0;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 900;
    margin-top: 0.15rem;
  }
  .icon-x  { background: oklch(93% 0.03 20);  color: oklch(48% 0.08 20); }
  .icon-ck { background: oklch(90% 0.07 145); color: oklch(35% 0.12 145); }

  /* ── REASONS GRID ── */
  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .reason-card {
    background: #fff;
    padding: 2rem 1.75rem;
    position: relative;
    transition: background 200ms;
  }
  .reason-card:hover { background: var(--cream); }
  .reason-num {
    font-family: var(--ff-display);
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
    color: var(--cream-2);
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
    font-variant-numeric: tabular-nums;
    transition: color 300ms var(--ease-out-quart);
  }
  .reason-card:hover .reason-num { color: oklch(88% 0.06 250); }
  .reason-card h3 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .reason-card p {
    font-size: 0.875rem;
    color: var(--ink-3);
    line-height: 1.7;
  }
  .reason-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: var(--accent);
    transition: height 350ms var(--ease-out-expo);
  }
  .reason-card:hover::after { height: 100%; }

  /* ── PULL QUOTE ── */
  .pull-quote {
    background: var(--navy-mid);
    padding: clamp(3rem, 7vw, 5rem) clamp(1.5rem, 5vw, 3rem);
    text-align: center;
  }
  .pull-quote blockquote {
    font-family: var(--ff-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.375rem, 3vw, 2.1rem);
    line-height: 1.4;
    color: #fff;
    max-width: 680px;
    margin: 0 auto 1.25rem;
    letter-spacing: -0.01em;
  }
  .pull-quote blockquote strong { font-weight: 700; font-style: normal; }
  .pull-quote cite {
    font-size: 0.8125rem;
    color: oklch(88% 0.06 250);
    font-style: normal;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* ── FEATURES LIST ── */
  .features-list {
    border-top: 1px solid var(--border);
  }
  .feature-item {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
    transition: padding 200ms var(--ease-out-quart);
  }
  .feature-emoji {
    width: 3rem;
    height: 3rem;
    background: var(--cream-2);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
    transition: background 200ms, transform 200ms var(--ease-out-expo);
  }
  .feature-item:hover .feature-emoji {
    background: oklch(92% 0.05 250);
    transform: scale(1.1);
  }
  .feature-body h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }
  .feature-body p {
    font-size: 0.875rem;
    color: var(--ink-3);
    line-height: 1.7;
  }

  /* ── FINAL CTA ── */
  .cta-section {
    background: var(--navy);
    padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 3rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 50% 100%, oklch(44% 0.14 250 / 0.2), transparent);
    pointer-events: none;
  }
  .cta-section .container { position: relative; z-index: 1; }
  .cta-section h2 {
    font-family: var(--ff-display);
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .cta-section h2 em { font-style: italic; color: var(--accent-lt); }
  .cta-section p {
    font-size: 1.0625rem;
    color: oklch(72% 0.02 260);
    max-width: 44ch;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
  }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 1rem 2.25rem;
    border-radius: 2px;
    text-decoration: none;
    transition: transform 200ms var(--ease-out-quart), opacity 150ms;
  }
  .btn-cta:hover { transform: translateY(-3px); opacity: 0.9; }
  .btn-cta svg { width: 1rem; height: 1rem; fill: currentColor; flex-shrink: 0; }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 600;
    color: oklch(60% 0.02 260);
    text-decoration: none;
    border-bottom: 1px solid oklch(40% 0.02 260);
    padding-bottom: 1px;
    transition: color 150ms, border-color 150ms;
  }
  .btn-ghost:hover { color: #fff; border-color: oklch(65% 0.02 260); }

  /* ── FOOTER ── */
  .footer {
    background: var(--navy);
    border-top: 1px solid oklch(28% 0.04 260);
    padding: 1.5rem clamp(1.5rem, 5vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer p { font-size: 0.8125rem; color: oklch(68% 0.02 260); }
  .footer a  { color: oklch(75% 0.02 260); text-decoration: underline; text-underline-offset: 2px; transition: color 150ms; }
  .footer a:hover { color: oklch(88% 0.02 260); }

  /* ── ANIMATIONS ── */
  @keyframes hero-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  /* Hero entrance — JS sets initial state inline, then animates in */

  /* Reveal classes — JS sets opacity:0 + transform as inline styles after DOM ready,
     then transitions to visible. No CSS default opacity:0 so layout never breaks. */

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  @media (max-width: 640px) {
    .reasons-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- Nav -->
<nav class="nav">
  <a href="/" class="nav-brand">Prop<span>Find</span></a>
  <a href="https://wa.me/6587423466" class="nav-cta" onclick="gtag('event','cta_click',{page:location.pathname,label:'nav-whatsapp'})">Get My Page</a>
</nav>

<main>
<!-- Hero -->
<section class="hero">
  <div class="hero-inner">
    <p class="hero-kicker">For Singapore Property Agents</p>
    <h1>Your Name Should Be<br>Bigger Than<br><em>Your Listings.</em></h1>
    <p class="hero-sub">
      Portals showcase properties — not you. A personal landing page puts your name, your track record, and your credibility front and centre.
    </p>
    <div class="hero-actions">
      <a href="https://wa.me/6587423466" class="btn-hero" onclick="gtag('event','cta_click',{page:location.pathname,label:'hero-whatsapp'})">
        <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Get My Page — $20/yr
      </a>
      <span class="hero-note">No tech skills needed. Done for you in days.</span>
    </div>
  </div>
</section>

<!-- Stats grid -->
<div class="stats-wrap">
  <div class="stats-grid">
