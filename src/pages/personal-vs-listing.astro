---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<style>
  :root {
    --color-primary: #1a1a2e;
    --color-accent: #e94560;
    --color-accent2: #0f3460;
    --color-light: #f8f9fa;
    --color-text: #333;
    --color-muted: #666;
    --font: 'Inter', sans-serif;
  }

  * { box-sizing: border-box; }

  body {
    font-family: var(--font);
    color: var(--color-text);
    background: #fff;
    margin: 0;
    padding: 0;
  }

  /* ── NAV ── */
  .nav {
    background: var(--color-primary);
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-brand {
    color: #fff;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .nav-cta {
    background: var(--color-accent);
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    white-space: nowrap;
  }

  /* ── HERO ── */
  .hero {
    background: var(--color-primary);
    color: #fff;
    text-align: center;
    padding: 5rem 2rem 4rem;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    max-width: 780px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero h1 span {
    color: var(--color-accent);
  }
  .hero-subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.75);
    max-width: 580px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .hero-cta {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.9rem 2.25rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .hero-cta:hover { opacity: 0.88; }

  /* ── SECTION COMMON ── */
  .section {
    padding: 4.5rem 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .section-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }
  .section-lead {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 680px;
  }

  /* ── COMPARISON TABLE ── */
  .compare-wrap {
    background: var(--color-light);
    padding: 4rem 2rem;
  }
  .compare-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .compare-inner .section-title {
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .compare-inner .section-lead {
    text-align: center;
    margin: 0 auto 2.5rem;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  }
  .compare-table thead tr {
    background: var(--color-primary);
    color: #fff;
  }
  .compare-table th {
    padding: 1rem 1.25rem;
    text-align: left;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
  }
  .compare-table th:first-child { width: 35%; }
  .compare-table td {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid #eee;
    vertical-align: top;
    line-height: 1.6;
  }
  .compare-table tbody tr:last-child td { border-bottom: none; }
  .compare-table tbody tr:nth-child(even) td { background: #fafafa; }
  .col-listing { color: #b91c1c; }
  .col-personal { color: #16a34a; font-weight: 600; }
  .icon-x::before { content: '✗ '; }
  .icon-check::before { content: '✓ '; }

  /* ── REASONS GRID ── */
  .reasons-wrap {
    background: #fff;
  }
  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.75rem;
    margin-top: 0.5rem;
  }
  .reason-card {
    background: var(--color-light);
    border-radius: 8px;
    padding: 1.75rem;
    border-top: 3px solid var(--color-accent);
  }
  .reason-number {
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .reason-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .reason-card p {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.65;
  }

  /* ── QUOTE BAND ── */
  .quote-band {
    background: var(--color-accent2);
    color: #fff;
    text-align: center;
    padding: 3.5rem 2rem;
  }
  .quote-band blockquote {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 700;
    line-height: 1.5;
    max-width: 680px;
    margin: 0 auto 1rem;
    font-style: italic;
  }
  .quote-band cite {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.65);
    font-style: normal;
  }

  /* ── STORY SECTION ── */
  .story-wrap {
    background: var(--color-light);
    padding: 4.5rem 2rem;
  }
  .story-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── FEATURE ROWS ── */
  .feature-row {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
    margin-bottom: 3rem;
  }
  .feature-row:last-child { margin-bottom: 0; }
  .feature-icon {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: #fff;
  }
  .feature-body h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .feature-body p {
    font-size: 0.92rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  /* ── CTA SECTION ── */
  .cta-wrap {
    background: var(--color-primary);
    color: #fff;
    text-align: center;
    padding: 5rem 2rem;
  }
  .cta-wrap h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    font-weight: 900;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .cta-wrap p {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.7);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-accent);
    color: #fff;
    padding: 0.9rem 2.25rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
  }
  .btn-secondary {
    background: transparent;
    color: #fff;
    padding: 0.9rem 2.25rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    border: 2px solid rgba(255,255,255,0.4);
  }

  /* ── FOOTER ── */
  .footer {
    background: var(--color-primary);
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 1.5rem 2rem;
    text-align: center;
    color: rgba(255,255,255,0.45);
    font-size: 0.8rem;
  }
  .footer a {
    color: rgba(255,255,255,0.55);
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .feature-row { flex-direction: column; gap: 1rem; }
    .compare-table th, .compare-table td { padding: 0.75rem 0.75rem; font-size: 0.85rem; }
    .hero { padding: 3.5rem 1.25rem 3rem; }
  }

  /* ── ANIMATIONS ── */

  /* Hero entrance */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .hero-eyebrow { animation: fadeDown 0.6s ease both; animation-delay: 0.1s; }
  .hero h1      { animation: fadeUp  0.7s ease both; animation-delay: 0.25s; }
  .hero-subtitle{ animation: fadeUp  0.7s ease both; animation-delay: 0.4s; }
  .hero-cta     { animation: fadeUp  0.7s ease both; animation-delay: 0.55s; }

  /* Scroll-reveal base state */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.from-left  { transform: translateX(-32px); }
  .reveal.from-right { transform: translateX(32px); }
  .reveal.visible {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* Stagger children inside grids */
  .reasons-grid .reason-card { transition-delay: 0s; }
  .reasons-grid .reason-card:nth-child(2) { transition-delay: 0.1s; }
  .reasons-grid .reason-card:nth-child(3) { transition-delay: 0.2s; }
  .reasons-grid .reason-card:nth-child(4) { transition-delay: 0.1s; }
  .reasons-grid .reason-card:nth-child(5) { transition-delay: 0.2s; }
  .reasons-grid .reason-card:nth-child(6) { transition-delay: 0.3s; }

  /* Table rows stagger */
  .compare-table tbody tr {
    opacity: 0;
    transform: translateX(-16px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .compare-table tbody tr.visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Card hover lift */
  .reason-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .reason-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  /* Feature icon pulse on hover */
  .feature-icon {
    transition: transform 0.25s ease;
  }
  .feature-row:hover .feature-icon {
    transform: scale(1.15);
  }

  /* CTA button hover */
  .btn-primary {
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); opacity: 0.9; }
  .btn-secondary {
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.7);
  }

  /* Quote band fade */
  .quote-band blockquote,
  .quote-band cite {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .quote-band cite { transition-delay: 0.2s; }
  .quote-band.visible blockquote,
  .quote-band.visible cite {
    opacity: 1;
    transform: translateY(0);
  }
</style>

