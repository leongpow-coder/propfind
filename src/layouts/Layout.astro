---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** matches slug key in og/[slug].png.ts — e.g. "home", "personal-vs-listing", "privacy" */
  ogSlug?: string;
  /** e.g. "" for homepage, "/personal-vs-listing" for inner pages */
  canonicalPath?: string;
  ogImageAlt?: string;
  /** og:type value — "website" (default) or "article" */
  ogType?: 'website' | 'article';
  robots?: string;
  extraSchema?: object | object[]; // additional JSON-LD schema objects to inject
}

const SITE = 'https://www.propfind.me';

const {
  title = 'Prop Find',
  description = "Stand out in Singapore's competitive property market with us—a sleek, professional website designed exclusively for real estate agents. Showcase your listings, highlight your expertise, and attract more clients with a personalized online presence.",
  ogSlug = 'home',
  canonicalPath = '',
  ogImageAlt = title,
  ogType = 'website',
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  extraSchema,
} = Astro.props;

const canonicalUrl = `${SITE}${canonicalPath}`;
const ogImageUrl   = `${SITE}/og/${ogSlug}.png`;

const schemaOrg = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Prop Find',
    url: SITE,
    logo: `${SITE}/assets/images/apple-touch-icon.png`,
    sameAs: [
      'https://twitter.com/propfindme',
      'https://wa.me/6587423466',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: canonicalUrl,
    inLanguage: 'en-SG',
    isPartOf: {
      '@type': 'WebSite',
      name: 'Prop Find',
      url: SITE,
    },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: ogImageUrl,
      width: 1200,
      height: 630,
    },
  },
];
---

<!doctype html>
<html lang="en-SG">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="color-scheme" content="light only" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    <!-- Open Graph -->
    <meta property="fb:app_id" content="0" />
    <meta property="og:site_name" content="Prop Find" />
    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_SG" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Article meta — only rendered when og:type is article -->
    {ogType === 'article' && (
      <>
        <meta property="article:published_time" content="2025-01-01T00:00:00+08:00" />
        <meta property="article:modified_time" content="2026-03-24T00:00:00+08:00" />
        <meta property="article:author" content="https://www.propfind.me" />
        <meta property="article:section" content="Real Estate" />
      </>
    )}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@propfindme" />
    <meta name="twitter:creator" content="@propfindme" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
    {extraSchema && <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?display=swap&family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,900;1,300;1,400;1,500;1,600;1,700;1,900" rel="stylesheet" type="text/css" />
    <slot name="head" />
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png" />
    <meta name="theme-color" content="#0f1624" />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-0JYBHZX4CB"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0JYBHZX4CB');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
